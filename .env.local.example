# Hugging Face API Configuration
# Get your free API key from https://huggingface.co/settings/tokens

# Required: Your Hugging Face API token
NEXT_PUBLIC_HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Recommended stable models (avoid stabilityai/stable-diffusion-2-1, it's deprecated):
# - runwayml/stable-diffusion-v1-5 (recommended, good quality)
# - prompthero/openjourney (excellent for character art)
# - CompVis/stable-diffusion-v1-4 (alternative option)
NEXT_PUBLIC_HF_MODEL=runwayml/stable-diffusion-v1-5
