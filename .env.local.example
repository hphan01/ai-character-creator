# Hugging Face API Configuration
# Get your free API key from https://huggingface.co/settings/tokens

# Required: Your Hugging Face API token
NEXT_PUBLIC_HF_API_KEY=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Primary model (optional - app will auto-fallback to other models if unavailable)
# Recommended models for fast character generation:
# - prompthero/openjourney-v4 (best reliability, great for character art)
# - CompVis/stable-diffusion-v1-4 (solid alternative)
# - runwayml/stable-diffusion-v1-5 (good quality)
# 
# If one model is overloaded, the app automatically tries others.
NEXT_PUBLIC_HF_MODEL=prompthero/openjourney-v4
